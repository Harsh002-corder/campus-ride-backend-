PORT=4000
NODE_ENV=development
MONGODB_URI=mongodb://127.0.0.1:27017/campus_rider
MONGODB_DB_NAME=campus_rider
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:8080,https://campusride-deploy.vercel.app
ALLOWED_ORIGINS=http://localhost:8080,https://campusride-deploy.vercel.app
ALLOWED_ORIGIN_PATTERNS=*.vercel.app
ALLOW_LAN_ORIGINS=false
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=
OTP_RETURN_IN_RESPONSE=false
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
OTP_TTL_MINUTES=10
MONGO_RECONNECT_MS=5000